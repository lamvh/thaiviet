# Supabase — powers both the CMS content row and admin media uploads (Storage).
# Find these under Project Settings → API. The publishable/anon key is safe to
# ship in the client bundle.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Storage setup (one-time, in the Supabase dashboard): create a PUBLIC bucket
# whose name matches VITE_SUPABASE_MEDIA_BUCKET below. Admin uploads land in
# images/… and videos/… and are served as https:// public URLs.
# Optional — defaults to `media` if unset. Override per environment (e.g. media-dev).
VITE_SUPABASE_MEDIA_BUCKET=media
